#!/usr/bin/env python3
"""
CAVMsearch — Search the CAVM with keyword analysis.

Usage:
  CAVMsearch <keyword1> [keyword2 ...] [options]

Examples:
  CAVMsearch python
  CAVMsearch python function
  CAVMsearch machine learning -n 5 -v

Options:
  -n N           Show top N results (default: 10)
  -b BASE        CAVM base directory (default: /home/JackrabbitAI/Memory/CAVM)
  -v             Show version history for each chain
  -s             Show response snippet matching the query
  --all-chains   Search ALL chains, including dormant
  --threshold T  Minimum similarity threshold (default: use CAVM default)

Output:
  For each matching chain, shows:
    • Chain ID (short)
    • Similarity score (0–1 scale)
    • Token statistics:
        - How many of YOUR keywords appear in the chain's latest version
        - Which tokens matched
        - Token counts (total and matched)
    • Chain metadata (versions, age, top tokens)
    • Optional: version history and response snippets
"""

import sys
import os
import argparse
from datetime import datetime, timezone

sys.path.insert(0, '/home/JackrabbitAI/Library')
import CAVMFunctions as CAVM


def iso_to_local(iso_str):
    try:
        dt = datetime.fromisoformat(iso_str)
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=timezone.utc)
        return dt.astimezone().strftime('%Y-%m-%d %H:%M:%S')
    except Exception:
        return iso_str


def age_human(dt):
    now = datetime.now(timezone.utc)
    if dt.tzinfo is None:
        dt = dt.replace(tzinfo=timezone.utc)
    delta = now - dt
    sec = delta.total_seconds()
    if sec < 60:    return f'{int(sec)}s ago'
    if sec < 3600:  return f'{int(sec/60)}m ago'
    if sec < 86400: return f'{int(sec/3600)}h ago'
    if sec < 2592000: return f'{int(sec/86400)}d ago'
    return f'{int(sec/2592000)}mo ago'


def parse_args():
    p = argparse.ArgumentParser(
        description='Search CAVM with keyword analysis and matching statistics',
        epilog="""
Examples:
  CAVMsearch python
  CAVMsearch "machine learning"
  CAVMsearch python function -n 5 -v
        """
    )
    p.add_argument('keywords', nargs='+',
                   help='One or more keywords/phrases to search for')
    p.add_argument('-n', '--number', type=int, default=10,
                   help='Maximum number of results to show (default: 10)')
    p.add_argument('-b', '--base', default='/home/JackrabbitAI/Memory/CAVM',
                   help='CAVM base directory')
    p.add_argument('-v', '--versions', action='store_true',
                   help='Show recent version history for each chain')
    p.add_argument('-s', '--show-snippet', action='store_true',
                   help='Include response snippet where keywords match')
    p.add_argument('--all-chains', action='store_true',
                   help='Search ALL chains, including dormant')
    p.add_argument('--threshold', type=float, default=None,
                   help='Minimum similarity threshold (overrides CAVM default)')
    p.add_argument('--debug-tokens', action='store_true',
                   help='Show full token breakdown for debugging')
    p.add_argument('-r', '--related', type=int, default=3,
                   help='Show top N related chains for each result (default: 3)')
    p.add_argument('--related-threshold', type=float, default=0.0,
                   help='Minimum similarity score to show a related chain (default: 0.0)')
    return p.parse_args()


def compute_token_stats(query_tokens, version_tokens):
    """
    Compute matching statistics between query tokens and version tokens.
    Returns: (matched_count, total_matched_weight, matched_tokens_list)
    """
    matched = []
    total_weight = 0
    for token, weight in version_tokens.items():
        if token in query_tokens:
            matched.append((token, weight))
            total_weight += weight
    matched_count = len(matched)
    matched.sort(key=lambda x: x[1], reverse=True)
    return matched_count, total_weight, matched


def top_related_chains(target_tokens, all_profiles, target_cid, cavm, k=3, min_score=0.0):
    """Return list of (score, cid, latest_v_idx) sorted desc excluding target_cid.

    - target_tokens: token dict for the target chain's latest version
    - all_profiles: dict of cid -> profile (candidate pool)
    - cavm: CAVM module instance (provides CosineLike, TopTokens)
    - k: number of related chains to return
    - min_score: minimum similarity to include
    """
    related = []
    if not target_tokens:
        return []

    # Precompute norm for fallback cosine if needed
    def fallback_cosine(a, b):
        num = 0.0
        for t, w in a.items():
            num += w * b.get(t, 0.0)
        denom_a = sum(v * v for v in a.values()) ** 0.5
        denom_b = sum(v * v for v in b.values()) ** 0.5
        denom = denom_a * denom_b
        return (num / denom) if denom else 0.0

    for other_cid, profile in all_profiles.items():
        if other_cid == target_cid:
            continue
        versions = profile.get('versions', [])
        if not versions:
            continue
        other_latest = versions[-1]
        other_tokens = other_latest.get('tokens', {})
        if not other_tokens:
            continue
        # Try to use cavm.CosineLike if available
        try:
            sc = cavm.CosineLike(target_tokens, other_tokens)
        except Exception:
            sc = fallback_cosine(target_tokens, other_tokens)
        if sc >= min_score:
            related.append((sc, other_cid, other_latest.get('v', len(versions))))

    related.sort(key=lambda x: x[0], reverse=True)
    return related[:k]


def format_score(score, threshold):
    """Visual indicator of match quality."""
    if score >= threshold * 1.5:
        return f"{score:.4f}  ★"
    elif score >= threshold:
        return f"{score:.4f}"
    else:
        return f"{score:.4f}  (below threshold)"


def main():
    args = parse_args()

    # Initialise CAVM
    cavm = CAVM.ContextAwareVersionedMemory(Base=args.base)

    # Determine threshold
    threshold = args.threshold if args.threshold is not None else cavm.SIMILARITY_THRESHOLD

    # Tokenise the query string (same way CAVM does)
    query_str = ' '.join(args.keywords)
    query_ctr = cavm.Tokenize(query_str)
    query_tokens_set = set(query_ctr.keys())

    if not query_ctr:
        print("Error: query contains no valid tokens after stop-word removal.")
        print(f"Tokens found: {args.keywords}")
        sys.exit(1)

    print(f"Query tokens: {sorted(query_ctr.keys())}")
    print(f"Similarity threshold: {threshold}")
    print(f"Searching...\n")

    # Perform search
    results = cavm.Search(query_str, limit=args.number)

    if not results:
        print("No matching chains found.")
        return

    # Fetch profiles for full data (we need version details)
    profiles = cavm.GetProfiles()
    dormant = cavm.LoadDormant(args.base) if not args.all_chains else set()

    # Filter dormant if requested
    if not args.all_chains:
        results = [(score, cid, vid, top) for score, cid, vid, top in results
                   if cid not in dormant]
        if not results:
            print("No active chains match that query.")
            return

    # Candidate pool for related comparisons: respect dormant filtering
    candidate_profiles = {cid: p for cid, p in profiles.items() if (args.all_chains or cid not in dormant)}

    print(f"{'='*70}")
    print(f"  SEARCH RESULTS  —  '{query_str}'")
    print(f"{'='*70}")
    print()

    for rank, (score, cid, v_idx, chain_top_tokens) in enumerate(results, 1):
        profile = profiles.get(cid)
        if not profile:
            continue  # chain deleted between search and fetch

        versions = profile.get('versions', [])
        latest = versions[-1] if versions else {}
        latest_tokens = latest.get('tokens', {})

        # Compute token overlap statistics
        matched_count, total_weight, matched_tokens = compute_token_stats(
            query_ctr, latest_tokens
        )
        total_chain_tokens = sum(latest_tokens.values())
        overlap_pct = (total_weight / total_chain_tokens * 100) if total_chain_tokens else 0

        # Human-readable relevance
        if score >= threshold * 1.5:
            relevance = "VERY HIGH"
        elif score >= threshold:
            relevance = "High"
        elif score >= threshold * 0.7:
            relevance = "Medium"
        else:
            relevance = "Low"

        print(f"[{rank:2d}] Score: {format_score(score, threshold)}  [{relevance}]")
        print(f"     Chain ID : {cid}")
        print(f"     Versions : {len(versions)}  (latest is v{latest.get('v','?')})")
        last_updated = latest.get('last_updated', '')
        print(f"     Updated  : {iso_to_local(last_updated)}  ({age_human(datetime.fromisoformat(last_updated) if last_updated else datetime.now(timezone.utc))})")
        print(f"     Total tokens in latest version : {total_chain_tokens}")

        # Token overlap analysis
        print(f"     Keyword overlap:")
        print(f"       Your keywords matched {matched_count} distinct token(s)")
        print(f"       Matched token weight in chain: {total_weight:.1f} / {total_chain_tokens}  ({overlap_pct:.1f}%)")

        if matched_tokens:
            # Show top matched tokens by weight
            top_matches = matched_tokens[:8]
            tokens_str = ', '.join(f"{tok}({wt:.0f})" for tok, wt in top_matches)
            if len(matched_tokens) > 8:
                tokens_str += f", ... (+{len(matched_tokens)-8})"
            print(f"       Matched: {tokens_str}")

        # Chain's own top tokens
        print(f"     Chain top tokens : {' '.join(chain_top_tokens[:10])}")

        # Optional snippet
        if args.show_snippet and latest.get('response'):
            resp = latest['response']
            snippet = resp[:180] + ('...' if len(resp) > 180 else '')
            print(f"     Latest response:")
            for line in snippet.split('\n')[:2]:
                print(f"       {line}")

        print()

        if args.versions and len(versions) > 1:
            print(f"     Recent versions (up to 5):")
            for v in reversed(versions[-5:]):
                vn = v.get('v', '?')
                vt = iso_to_local(v.get('last_updated', ''))
                vtok = cavm.TopTokens(v.get('tokens', {}), 5)
                inp = (v.get('input', '') or '')[:80]
                print(f"       v{vn}: {vt}  tokens: {' '.join(vtok)}")
                if inp:
                    print(f"            input: {inp!r}")
            if len(versions) > 5:
                print(f"       ... (+{len(versions)-5} older)")
            print()

        # Debug token table
        if args.debug_tokens:
            print(f"     [DEBUG] Full token vector for latest version:")
            # Sort by weight desc, show top 15
            sorted_tokens = sorted(latest_tokens.items(), key=lambda x: x[1], reverse=True)
            for tok, wt in sorted_tokens[:15]:
                marker = " <— matched" if tok in query_tokens_set else ""
                print(f"       {tok:20s}: {wt:6.1f}{marker}")
            if len(sorted_tokens) > 15:
                print(f"       ... ({len(sorted_tokens)-15} more tokens)")
            print()

        # Related chains
        if args.related and candidate_profiles:
            rel = top_related_chains(latest_tokens, candidate_profiles, cid, cavm, k=args.related, min_score=args.related_threshold)
            if rel:
                print(f"     Related chains (top {len(rel)}):")
                for r_score, r_cid, r_v in rel:
                    r_profile = profiles.get(r_cid)
                    r_latest = r_profile['versions'][-1] if r_profile else {}
                    r_top = cavm.TopTokens(r_latest.get('tokens', {}), 6)
                    print(f"       - {r_cid}  score={r_score:.4f}  v{r_v}  top: {' '.join(r_top[:6])}")
                print()

    print(f"{'='*70}")
    print(f"  Found {len(results)} chain(s) matching query.")
    if dormant and not args.all_chains:
        print(f"  (Dormant chains excluded. Use --all-chains to include them.)")


if __name__ == '__main__':
    main()
