#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import sys
import re

def tokenize(expr):
    """Convert expression string into tokens (numbers, operators, parentheses)"""
    tokens = []
    pos = 0
    while pos < len(expr):
        # Skip whitespace
        if expr[pos].isspace():
            pos += 1
            continue
        
        # Match numbers (integers and decimals)
        if expr[pos].isdigit() or (expr[pos] == '.' and pos + 1 < len(expr) and expr[pos+1].isdigit()):
            match = re.match(r'\d*\.?\d+', expr[pos:])
            if not match:
                raise ValueError("Invalid number format")
            tokens.append(match.group())
            pos += match.end()
            continue
        
        # Match operators and parentheses
        if expr[pos] in '+-*/()':
            tokens.append(expr[pos])
            pos += 1
            continue
        
        raise ValueError(f"Unexpected character: {expr[pos]}")
    
    return tokens

def shunting_yard(tokens):
    """Convert infix tokens to postfix using Shunting Yard algorithm"""
    precedence = {'*': 2, '/': 2, '+': 1, '-': 1}
    output = []
    stack = []
    
    for token in tokens:
        # Numbers go directly to output
        if re.match(r'\d*\.?\d+', token):
            output.append(token)
            continue
        
        # Handle parentheses
        if token == '(':
            stack.append(token)
            continue
        if token == ')':
            while stack and stack[-1] != '(':
                output.append(stack.pop())
            if not stack or stack.pop() != '(':
                raise ValueError("Mismatched parentheses")
            continue
        
        # Handle operators
        if token in precedence:
            while (stack and stack[-1] != '(' and 
                   stack[-1] in precedence and
                   precedence[stack[-1]] >= precedence[token]):
                output.append(stack.pop())
            stack.append(token)
            continue
        
        raise ValueError(f"Invalid token: {token}")
    
    # Pop remaining operators to output
    while stack:
        if stack[-1] == '(':
            raise ValueError("Mismatched parentheses")
        output.append(stack.pop())
    
    return output

def evaluate_postfix(tokens):
    """Evaluate postfix expression"""
    stack = []
    for token in tokens:
        if token in '+-*/':
            if len(stack) < 2:
                raise ValueError("Insufficient operands")
            b = float(stack.pop())
            a = float(stack.pop())
            
            if token == '+': result = a + b
            elif token == '-': result = a - b
            elif token == '*': result = a * b
            elif token == '/': 
                if abs(b) < 1e-9:
                    raise ZeroDivisionError("Division by zero")
                result = a / b
            stack.append(result)
        else:
            stack.append(float(token))
    
    if len(stack) != 1:
        raise ValueError("Invalid expression")
    return stack[0]

def format_result(value):
    """Format result cleanly: integers without decimals, floats without trailing zeros"""
    if value.is_integer():
        return str(int(value))
    return f"{value:.6f}".rstrip('0').rstrip('.')

def calculate(expr):
    """Main calculation pipeline"""
    tokens = tokenize(expr)
    postfix = shunting_yard(tokens)
    return evaluate_postfix(postfix)

def main():
    # CLI mode (single expression)
    if len(sys.argv) > 1:
        expr = " ".join(sys.argv[1:])
        try:
            result = calculate(expr)
            print(format_result(result))
            sys.exit(0)
        except Exception as e:
            print(f"Error: {str(e)}", file=sys.stderr)
            sys.exit(1)
    
    # Interactive mode
    print("Advanced Calculator - Type 'exit' to quit")
    print("Supports: + - * / ( ) and order of operations")
    print("Example: 3 + 4 * (2 - 1)")
    
    while True:
        try:
            expr = input("\n> ").strip().lower()
            if expr in ('exit', 'quit'):
                print("Goodbye!")
                break
            if not expr:
                continue
                
            result = calculate(expr)
            print(f"= {format_result(result)}")
            
        except Exception as e:
            print(f"Error: {str(e)}")

if __name__ == "__main__":
    main()

