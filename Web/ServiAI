def LoadAIConversation(addr,user_id):
    try:
        # Just something to prime the agent to access memory. NO calls here.
        persona='None'
        engine=os.getenv('JRAIengine', 'openai')
        model=os.getenv('JRAImodel', 'gpt-5-nano')
        tokens=os.getenv('JRAItokens', 128000)
        tokens=int(tokens)

        agent = AI.Agent(
            engine=engine,
            model=model,
            maxtokens=tokens,
            persona=persona,
            reset=False,
            save=True,
            usertokens=TOKEN_DIR
        )
        agent.SetMemory(memory=MEMORY_DIR)
        agent.Read()

        # Read messages
        messages=[]
        for item in agent.Memory:
            role=item["role"]
            content=item["content"]

            # Skip system prompts & empty content & token counts etc.
            valid_roles=["user","assistant"]
            valid_content=len(content.strip())>3 and "\\n" not in content[:4]

            if role.lower() in valid_roles: # and valid_content: # and len(messages)<6:
                messages.append({"role":role,"content":content})

        result={"status":"success","messages":messages}
    except Exception as errr: # Note double r avoids conflict w/err var later!
        WriteLog(addr,f"HISTORY ERR:{str(errr)}")
        result={"status":"error","message":"No prior session"}

    return json.dumps(result).encode('utf-8')

def ProcessAI(addr, payload, user_id):
    try:
        # Clean input using CoreFunctions
        data = json.loads(payload)

        # Extract the message for the AI model
        user_text = data.get("message", "")
        # user_id = data.get("user_id", "web_user")

        # Normalize text using CoreFunctions
        user_text = CF.DecodeUnicode(user_text)

        # OS Load Management: Lower priority for the AI worker fork
        # CF.renice(CF.MasterNice + 5)

        # Initialize Agent based on working example parameters
        # We pull engine/model from Env or defaults if not in payload
        engine=data.get("engine", 'None')
        model=data.get("model", 'None')
        tokens=data.get("tokens", 'None')
        persona=data.get("persona",'None')

        if engine.lower()=='default' or engine.lower()=='none':
            engine=os.getenv('JRAIengine', 'openai')
        if model.lower()=='default' or model.lower()=='none':
            model=os.getenv('JRAImodel', 'gpt-5-nano')
        if tokens.lower()=='default' or tokens.lower()=='none':
            tokens=os.getenv('JRAItokens', 128000)
        tokens=int(tokens)

        agent = AI.Agent(
            engine=engine,
            model=model,
            maxtokens=tokens,
            persona=persona,
            reset=False,
            save=True,
            usertokens=TOKEN_DIR
        )
        agent.SetMemory(memory=MEMORY_DIR)

        # Get response (Blocks in this child process fork)
        response = agent.Response(user_text)

        result = {"status": "success", "reply": response}
    except Exception as err:
        WriteLog(addr, f"AI ERROR: {str(err)}")
        result = {"status": "error", "message": "ServiAI processing failure."}

    return json.dumps(result).encode('utf-8')

def EraseMemory(addr, user_id):
    try:
        engine=os.getenv('JRAIengine', 'openai')
        model=os.getenv('JRAImodel', 'gpt-5-nano')
        tokens=int(os.getenv('JRAItokens', 128000))

        agent = AI.Agent(
            engine=engine,
            model=model,
            maxtokens=tokens,
            persona='None',
            reset=False,
            save=True,
            usertokens=TOKEN_DIR
        )
        agent.SetMemory(memory=MEMORY_DIR)
        agent.Reset()

        res=json.dumps({"status":"success","message":"Memory erased"}).encode('utf-8')
    except Exception as err:
        WriteLog(addr, f"ERASE ERROR: {str(err)}")
        res=json.dumps({"status":"error","message":"Erase failed"}).encode('utf-8')
    return res

# =============================================================================
# 5. SERVER HANDLER
# =============================================================================

class Handler(BaseHTTPRequestHandler):
    BaseHTTPRequestHandler.server_version='ServiAI/'+VERSION
    BaseHTTPRequestHandler.sys_version=''

    def log_message(self,format,*args):
        addr=self.client_address[0]
        WriteLog(addr, f"{args}")

    def do_GET(self):
        addr = self.client_address[0]

        # MUST BE FIRST CHECK
        if not CheckIPaddress(str(addr)):
            self.send_response(403)
            self.end_headers()
            self.wfile.write(NO_HTML.encode('utf-8'))
            return

        # User ID must be available ALWAYS

        user_id = self.headers.get("X-ServiAIOpenSession")

        if self.path!="/" and self.path!="/index.html" \
        and (not user_id or user_id == "undefined"):
            res=json.dumps({"status":"error","message":"Missing session ID"}).encode('utf-8')
            self.send_response(400)
            self.end_headers()
            self.wfile.write(res)
            return

        # Read history from the server
        if self.path == "/history":
            res=LoadAIConversation(addr, user_id)

            ln=str(len(res))
            self.send_response(200)
            headers=[
                ("Content-type","application/json"),
                ("Content-Length",ln),
                ("Access-Control-Allow-Origin","*") ]

            for k,v in headers:
                self.send_header(k,v)
            self.end_headers()

            self.wfile.write(res);
            return

        # Get index.html
        if self.path == "/" or self.path == "/index.html":
            self.send_response(200)
            self.send_header("Content-type", "text/html")
            self.end_headers()
            content = FF.ReadFile(UI_HTML_FILE)
            self.wfile.write(content.encode('utf-8') if content else b"UI Missing")
            return

        # No matches, fall through 404
        self.send_response(404)
        self.end_headers()
        self.wfile.write(NO_HTML.encode('utf-8'))

    def do_POST(self):
        addr = self.client_address[0]

        # MUST BE FIRST CHECK
        if not CheckIPaddress(str(addr)):
            self.send_response(403)
            self.end_headers()
            return

        user_id = self.headers.get("X-ServiAIOpenSession")

        if not user_id or user_id == "undefined":
            res=json.dumps({"status":"error","message":"Missing session ID"}).encode('utf-8')
            self.send_response(400)
            self.end_headers()
            self.wfile.write(res)
            return

        # Erase memory
        if self.path == "/erase":
            res=EraseMemory(addr, user_id)

            self.send_response(200)
            self.send_header("Content-type", "application/json")
            self.end_headers()
            self.wfile.write(res)
            return

        if self.path == "/chat":
            content_len=int(self.headers.get('content-length', 0))
            payload=self.rfile.read(content_len).decode('utf-8')

            # Child fork handles this blocking call
            res = ProcessAI(addr, payload, user_id)
            if res is None:
                res=b'Service did not respond.'

            self.send_response(200)
            self.send_header("Content-type", "application/json")
            self.end_headers()

            self.wfile.write(res)
            return

        # No matches, fall through 404
        self.send_response(404)
        self.end_headers()
        self.wfile.write(NO_HTML.encode('utf-8'))

class ForkingSimpleServer(ForkingMixIn, HTTPServer):
    pass

def main():
    port = int(sys.argv[1]) if len(sys.argv) > 1 else 13131

    FF.mkdir(LOG_DIR)
    FF.mkdir(MEMORY_DIR)

#    if not os.path.exists(IDENTITY_FILE) or not os.path.exists(IP_LIST_FILE):
#        print("Required Config Files Missing.")
#        sys.exit(2)

    WritePID(port)
    WriteLog("SYSTEM", f"Servi Online on port {port}")

    try:
        server = ForkingSimpleServer(('', port), Handler)
        server.serve_forever()
    except KeyboardInterrupt:
        pass

if __name__ == '__main__':
    main()

